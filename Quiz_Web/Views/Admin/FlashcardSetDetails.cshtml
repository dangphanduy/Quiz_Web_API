@model Quiz_Web.Models.Entities.FlashcardSet
@{
    ViewData["Title"] = "Chi tiết bộ Flashcard";
    Layout = "_LayoutAdmin";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Chi tiết bộ Flashcard: @Model.Title</h2>
    <div>
        <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addCardModal">
            <i class="bi bi-plus-circle me-1"></i> Thêm thẻ mới
        </button>
        <a href="@Url.Action("FlashcardSets")" class="btn btn-secondary">Quay lại danh sách</a>
    </div>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="card-title mb-0">Thông tin bộ Flashcard</h5>
            </div>
            <div class="card-body text-center">
                <div class="mb-3">
                    @if (!string.IsNullOrEmpty(Model.CoverUrl))
                    {
                        <img src="@Model.CoverUrl" alt="@Model.Title" class="img-thumbnail" style="max-height: 180px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="bg-light text-secondary rounded py-5">
                            <i class="fas fa-layer-group fa-3x"></i>
                            <div class="mt-2 text-muted">Chưa có ảnh bìa</div>
                        </div>
                    }
                </div>
            </div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item"><strong>Người tạo:</strong> @(Model.Owner?.FullName ?? "Hệ thống")</li>
                <li class="list-group-item"><strong>Trạng thái hiển thị:</strong> 
                    <span class="badge @(Model.Visibility == "Public" ? "bg-success" : "bg-warning")">
                        @(Model.Visibility == "Public" ? "Công khai" : "Riêng tư")
                    </span>
                </li>
                <li class="list-group-item"><strong>Ngôn ngữ:</strong> @(Model.Language ?? "Không xác định")</li>
                <li class="list-group-item"><strong>Mô tả:</strong> @(Model.Description ?? "Không có mô tả")</li>
                <li class="list-group-item"><strong>Tags:</strong> @(Model.TagsText ?? "Không có tags")</li>
                <li class="list-group-item"><strong>Ngày tạo:</strong> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</li>
                @if (Model.UpdatedAt.HasValue)
                {
                    <li class="list-group-item"><strong>Cập nhật lần cuối:</strong> @Model.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")</li>
                }
                <li class="list-group-item"><strong>Tổng số thẻ:</strong> <span class="badge bg-info text-white">@Model.Flashcards.Count thẻ</span></li>
            </ul>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">Danh sách thẻ (@Model.Flashcards.Count)</h5>
            </div>
            <div class="card-body">
                @if (Model.Flashcards.Any())
                {
                    <div class="row row-cols-1 row-cols-md-2 g-3">
                        @foreach (var card in Model.Flashcards)
                        {
                            <div class="col">
                                <div class="card h-100 border-start border-primary border-4 shadow-sm">
                                    <div class="card-body d-flex flex-column justify-content-between">
                                        <div>
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <span class="badge bg-secondary">#@card.OrderIndex</span>
                                                @if (!string.IsNullOrEmpty(card.Hint))
                                                {
                                                    <span class="text-muted small" title="Gợi ý: @card.Hint">
                                                        <i class="bi bi-info-circle-fill"></i> Có gợi ý
                                                    </span>
                                                }
                                            </div>
                                            
                                            <div class="mb-3">
                                                <strong class="text-primary d-block small mb-1">MẶT TRƯỚC (Front)</strong>
                                                <div class="p-2 bg-light rounded text-dark text-wrap" style="min-height: 45px; word-break: break-all;">@card.FrontText</div>
                                            </div>

                                            <div class="mb-3">
                                                <strong class="text-success d-block small mb-1">MẶT SAU (Back)</strong>
                                                <div class="p-2 bg-light rounded text-dark text-wrap" style="min-height: 45px; word-break: break-all;">@card.BackText</div>
                                            </div>

                                            @if (!string.IsNullOrEmpty(card.Hint))
                                            {
                                                <div class="mb-2">
                                                    <strong class="text-warning d-block small mb-1">Gợi ý</strong>
                                                    <span class="text-muted small">@card.Hint</span>
                                                </div>
                                            }
                                        </div>

                                        <div class="d-flex justify-content-end gap-2 mt-3 pt-2 border-top">
                                            <button type="button" class="btn btn-sm btn-outline-primary edit-card-btn"
                                                    data-id="@card.CardId"
                                                    data-front="@card.FrontText"
                                                    data-back="@card.BackText"
                                                    data-hint="@card.Hint"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#editCardModal">
                                                <i class="bi bi-pencil-square"></i> Sửa
                                            </button>
                                            <form method="post" asp-action="DeleteFlashcardFromSet" class="d-inline">
                                                <input type="hidden" name="id" value="@card.CardId" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Bạn có chắc muốn xóa thẻ này không?')">
                                                    <i class="bi bi-trash"></i> Xóa
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-postcard fa-3x d-block mb-3"></i>
                        Bộ flashcard này chưa có thẻ nào. Hãy nhấp nút <strong>Thêm thẻ mới</strong> để bắt đầu!
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Add Card Modal -->
<div class="modal fade" id="addCardModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-action="AddFlashcardToSet">
                <input type="hidden" name="setId" value="@Model.SetId" />
                <div class="modal-header">
                    <h5 class="modal-title">Thêm thẻ flashcard mới</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Mặt trước (Câu hỏi / Từ vựng) *</label>
                        <textarea name="frontText" class="form-control" rows="3" required placeholder="Nhập câu hỏi hoặc từ vựng..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mặt sau (Câu trả lời / Định nghĩa) *</label>
                        <textarea name="backText" class="form-control" rows="3" required placeholder="Nhập câu trả lời hoặc định nghĩa..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Gợi ý (Tùy chọn)</label>
                        <input type="text" name="hint" class="form-control" placeholder="Nhập gợi ý nhỏ nếu có..." />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-success">Thêm thẻ</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Card Modal -->
<div class="modal fade" id="editCardModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-action="EditFlashcardInSet">
                <input type="hidden" name="cardId" id="editCardId" />
                <div class="modal-header">
                    <h5 class="modal-title">Chỉnh sửa thẻ flashcard</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Mặt trước (Câu hỏi / Từ vựng) *</label>
                        <textarea name="frontText" id="editFrontText" class="form-control" rows="3" required></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mặt sau (Câu trả lời / Định nghĩa) *</label>
                        <textarea name="backText" id="editBackText" class="form-control" rows="3" required></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Gợi ý (Tùy chọn)</label>
                        <input type="text" name="hint" id="editHint" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Populate fields in edit modal
            $('.edit-card-btn').on('click', function () {
                var cardId = $(this).data('id');
                var frontText = $(this).data('front');
                var backText = $(this).data('back');
                var hint = $(this).data('hint');

                $('#editCardId').val(cardId);
                $('#editFrontText').val(frontText);
                $('#editBackText').val(backText);
                $('#editHint').val(hint);
            });
        });
    </script>
}
