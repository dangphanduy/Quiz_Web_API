@{
    ViewData["Title"] = "Kết quả thanh toán";
    Layout = "_Layout";
    var isSubscription = ViewBag.PaymentPurpose == Quiz_Web.Models.Entities.PaymentPurposes.Subscription;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body text-center p-5">
                    @if (ViewBag.Success == true)
                    {
                        <i class="fas fa-check-circle fa-4x text-success mb-3"></i>
                        <h3 class="text-success">Thanh toán thành công!</h3>
                        <div class="alert alert-success mt-3">
                            @if (isSubscription)
                            {
                                <p class="mb-0">Gói thuê bao đã được kích hoạt hoặc gia hạn. Bạn có thể xem toàn bộ khóa học trong thời hạn gói.</p>
                            }
                            else
                            {
                                <p class="mb-0">Bạn đã mua khóa học thành công và có quyền truy cập vĩnh viễn.</p>
                            }
                        </div>
                    }
                    else
                    {
                        <i class="fas fa-times-circle fa-4x text-danger mb-3"></i>
                        <h3 class="text-danger">Thanh toán thất bại</h3>
                        <div class="alert alert-danger mt-3">
                            Giao dịch chưa hoàn tất. Bạn có thể thử lại sau.
                        </div>
                    }

                    <p class="mt-3 fs-5">@ViewBag.Message</p>
                    <div class="mt-4">
                        @if (isSubscription)
                        {
                            <a asp-controller="Subscription" asp-action="Pricing" class="btn btn-primary me-2">Xem gói thuê bao</a>
                        }
                        else if (ViewBag.Success == true)
                        {
                            <a asp-controller="Library" asp-action="Library" class="btn btn-primary me-2">Khóa học của tôi</a>
                        }
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">Về trang chủ</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
