@model List<Quiz_Web.Models.Entities.CartItem>
@{
    ViewData["Title"] = "Chọn phương thức thanh toán";
    var total = ViewBag.Total as decimal? ?? 0;
    var cartItems = ViewBag.CartItems as List<Quiz_Web.Models.Entities.CartItem> ?? new List<Quiz_Web.Models.Entities.CartItem>();
}

<link rel="stylesheet" href="~/css/payment-method.css" asp-append-version="true" />

<div class="payment-method-container">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card shadow">
                    <div class="card-header bg-primary text-white">
                        <h3 class="mb-0">
                            <i class="bi bi-credit-card me-2"></i>Chọn phương thức thanh toán
                        </h3>
                    </div>
                    <div class="card-body">
                        <!-- Order Summary -->
                        <div class="order-summary mb-4 p-3 bg-light rounded">
                            <h5 class="mb-3">Thông tin đơn hàng</h5>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Số lượng khóa học:</span>
                                <strong>@cartItems.Count</strong>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Tổng tiền:</span>
                                <strong class="text-primary fs-4">@total.ToString("N0") ₫</strong>
                            </div>
                        </div>

                        <!-- Payment Methods -->
                        <h5 class="mb-3">Chọn phương thức</h5>
                        <div class="payment-methods">
                            <!-- MoMo Payment -->
                            <div class="payment-method-item mb-3">
                                <input type="radio" class="btn-check" name="payment-method" id="payos" value="payos" checked>
                                <label class="btn btn-outline-primary w-100 text-start payment-method-label" for="payos">
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-qr-code fs-3 me-3 text-primary"></i>
                                        <div>
                                            <h6 class="mb-1">Cổng thanh toán PayOS (VietQR)</h6>
                                            <small class="text-muted">Thanh toán qua mã QR ngân hàng VietQR</small>
                                        </div>
                                    </div>
                                </label>
                            </div>

                            <!-- Other Payment Methods (Disabled for now) -->
                            <div class="payment-method-item mb-3">
                                <label class="btn btn-outline-secondary w-100 text-start payment-method-label disabled" style="opacity: 0.5;">
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-credit-card fs-3 me-3"></i>
                                        <div>
                                            <h6 class="mb-1">Thẻ tín dụng/Ghi nợ <span class="badge bg-secondary">Sắp có</span></h6>
                                            <small class="text-muted">Visa, Mastercard, JCB</small>
                                        </div>
                                    </div>
                                </label>
                            </div>

                            <div class="payment-method-item mb-3">
                                <label class="btn btn-outline-secondary w-100 text-start payment-method-label disabled" style="opacity: 0.5;">
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-bank fs-3 me-3"></i>
                                        <div>
                                            <h6 class="mb-1">Chuyển khoản ngân hàng <span class="badge bg-secondary">Sắp có</span></h6>
                                            <small class="text-muted">Chuyển khoản trực tiếp</small>
                                        </div>
                                    </div>
                                </label>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-grid gap-2 mt-4">
                            <button type="button" class="btn btn-primary btn-lg btn-payos-payment" id="btnProceedPayment">
                                <i class="bi bi-check-circle me-2"></i>Tiếp tục thanh toán
                            </button>
                            <a href="/checkout" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-2"></i>Quay lại giỏ hàng
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/payment.js" asp-append-version="true"></script>
}
