@{
	Layout = "_LayoutAccount";
	ViewData["Title"] = "Forgot Password";
}
<section class="container" id="forgot_password">
	<div class="auth-wrapper p-5 mt-5">
		<div class="auth-image" style="background-image: url('/asset/image/Login.svg');">
		</div>

		<div class="auth-form">
			<div class="auth-card">
				<div class="text-center mb-4">
					<h4 id="forgot_password_title">Quên mật khẩu</h4>
					<p id="forgot_password_desc" class="text-muted small">Nhập email của bạn để nhận mã xác thực đặt lại mật khẩu</p>
				</div>

				<form id="forgot_password_form" method="post">
					@Html.AntiForgeryToken()
					<div class="mb-3">
						<label>Email</label>
						<input type="email" name="email" id="emailInput" class="form-control auth-input"
							   placeholder="Nhập email của bạn" required />
					</div>
					<button type="submit" class="btn btn-primary btn-auth">Gửi yêu cầu</button>
					<div class="d-flex justify-content-center align-items-center mt-3">
						<a href="@Url.Action("Login", "Account")" class="text-decoration-none small text-primary">
							 Quay lại đăng nhập
						</a>
					</div>
				</form>

				<form id="otp_verification_form" method="post" style="display: none;">
					@Html.AntiForgeryToken()
					<input type="hidden" id="otpEmailInput" name="email" />
					<div class="mb-3">
						<label class="form-label d-block text-start">Mã xác thực (6 số)</label>
						<input type="text" name="code" id="otpCodeInput" class="form-control auth-input text-center font-monospace fw-bold"
							   placeholder="000000" maxlength="6" pattern="\d{6}" required 
							   style="font-size: 1.5rem; letter-spacing: 0.5rem; border-color: #0d6efd;" />
					</div>
					<button type="submit" class="btn btn-primary btn-auth">Xác thực</button>
					<div class="d-flex justify-content-between align-items-center mt-3">
						<a href="#" id="resendOtpBtn" class="text-decoration-none small text-secondary">Gửi lại mã</a>
						<a href="@Url.Action("Login", "Account")" class="text-decoration-none small text-primary">
							 Quay lại đăng nhập
						</a>
					</div>
				</form>
			</div>
		</div>
	</div>
</section>