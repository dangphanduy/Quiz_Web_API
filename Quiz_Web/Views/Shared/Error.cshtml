@model Quiz_Web.Models.ErrorViewModel
@{
    Layout = null;
    ViewData["Title"] = "Error";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Error - Quiz Web</title>
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #f6f7f9;
            color: #222;
        }

        main {
            max-width: 720px;
            margin: 12vh auto;
            padding: 32px;
            background: #fff;
            border: 1px solid #e5e7eb;
        }

        h1 {
            margin: 0 0 12px;
            font-size: 28px;
        }

        p {
            margin: 8px 0;
            line-height: 1.5;
        }

        code {
            background: #f1f3f5;
            padding: 2px 6px;
        }
    </style>
</head>
<body>
    <main>
        <h1>Đã xảy ra lỗi</h1>
        <p>Hệ thống đang gặp sự cố. Vui lòng thử lại sau.</p>
        @if (!string.IsNullOrWhiteSpace(Model?.RequestId))
        {
            <p>Mã truy vết: <code>@Model.RequestId</code></p>
        }
    </main>
</body>
</html>
